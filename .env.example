# ================================================
# CONFIGURACIÓN DEL SISTEMA DE FACTURAS CON OCR
# ================================================

# DESARROLLO vs PRODUCCIÓN
NODE_ENV=development
# NODE_ENV=production

# ================================================
# SERVIDOR
# ================================================
PORT=3000
API_URL=http://localhost:3000

# ================================================
# BASE DE DATOS - PostgreSQL
# ================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_facturas
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura_aqui

# Pool de conexiones
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ================================================
# AUTENTICACIÓN - JWT
# ================================================
# Generar una contraseña fuerte con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_muy_seguro_con_caracteres_aleatorios_12345
JWT_EXPIRATION=7d

# ================================================
# CARGA DE ARCHIVOS - Multer
# ================================================
MAX_FILE_SIZE=10485760  # 10MB en bytes
UPLOAD_DIR=./uploads

# ================================================
# OCR - Tesseract
# ================================================
ENABLE_OCR=true
OCR_LANGUAGE=spa
# Otros idiomas: eng (inglés), fra (francés), por (portugués), etc.

# ================================================
# EMAIL - SMTP (Opcional, para notificaciones)
# ================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_aplicacion

# ================================================
# FRONTEND
# ================================================
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://app.tudominio.com (producción)

# ================================================
# REPORTES
# ================================================
REPORT_FORMAT=pdf
TIMEZONE=America/Tegucigalpa
# Otros: America/New_York, Europe/London, etc.

# ================================================
# LOGGING
# ================================================
LOG_LEVEL=info
# Valores: error, warn, info, debug

# ================================================
# CORS
# ================================================
CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://app.tudominio.com (producción)

# ================================================
# AWS (Opcional, para almacenamiento S3)
# ================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ================================================
# REDIS (Opcional, para caching)
# ================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================================
# MONGODB (Opcional, si usas para auditoría)
# ================================================
MONGODB_URI=mongodb://localhost:27017/sistema_facturas

# ================================================
# INTEGRACIÓN CON OTROS SERVICIOS
# ================================================
# Google Cloud Vision API (Alternativa OCR)
GOOGLE_VISION_API_KEY=

# Stripe (Si implementas pagos)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# ================================================
# DESARROLLO AVANZADO
# ================================================
# Swagger/OpenAPI
SWAGGER_ENABLED=true

# Request logging (Morgan)
REQUEST_LOG=combined

# Database query logging
QUERY_LOG=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests por ventana

# ================================================
# SEGURIDAD
# ================================================
# HTTPS/SSL
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# Helmet - Security headers
HELMET_ENABLED=true

# Session timeout (minutos)
SESSION_TIMEOUT=30

# ================================================
# MONITOREO Y ANALYTICS
# ================================================
# Sentry (Error tracking)
SENTRY_DSN=

# Datadog (APM)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ================================================
# CONFIGURACIONES POR ENTORNO
# ================================================

# DEVELOPMENT ONLY
DEBUG=true
SEED_DATABASE=false
FORCE_MIGRATE=false

# PRODUCTION ONLY
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30
